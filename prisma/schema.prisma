generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ================= ENUMS =================
enum Role {
  ADMIN
}

// Leads Enums
enum LeadSource {
  INDIAMART
  JUSTDIAL
  WEBSITE
  GOOGLE_ADS
  FACEBOOK_INSTAGRAM
  REFERENCE
  COLD_CALL
  OTHER
}

enum ProductInterest {
  CARD_DESIGN
  FLEX_DESIGN
  BANNER
  STICKER
  SIGNAGE_BOARD
  OTHER
}

enum LeadStage {
  NEW
  CONTACTED
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

// Customers Enums
enum CustomerType {
  RETAIL
  WHOLESALE
  ENTERPRISE
}

// Orders Enums
enum OrderType {
  RETAIL_DEALER
  ONLINE
}

enum OrderSource {
  WEBSITE
  MEESHO
  AMAZON
  INSTAGRAM
  OTHER
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// Inventory Enums
enum InventoryType {
  RAW_MATERIAL
  FINISHED_GOOD
}

enum InventoryCategory {
  RAW_MATERIAL
  CONSUMABLES
  HARDWARE
  PACKAGING
  FINISHED_GOODS
}

enum StockTransactionType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

enum StockTransactionReason {
  PURCHASE
  MANUAL_ADJUSTMENT
  PRODUCTION_USAGE
  RETURN
  CORRECTION
  DAMAGED
  LOST
}

enum ReferenceType {
  PURCHASE
  MANUAL
  INVOICE
  ADJUSTMENT
}

// Purchases & Expenses Enums
enum PurchaseType {
  CASH
  SUPPLIER
  MARKET
  ONLINE
}

enum PurchasePaymentStatus {
  PAID
  PENDING
  PARTIAL
}

enum PurchaseDeliveryStatus {
  RECEIVED
  PENDING
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  UPI
  CHEQUE
  CREDIT
  CARD
  OTHER
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum ExpenseCategory {
  OFFICE_SUPPLIES
  TRAVEL
  UTILITIES
  SALARY
  MARKETING
  MAINTENANCE
  OTHER
}

enum ExpensePaymentStatus {
  PAID
  PENDING
  PARTIALLY_PAID
}

enum ExpenseStatus {
  PAID
  PENDING
}

enum PaidToType {
  SUPPLIER
  EMPLOYEE
  OTHER
}

// Invoices & Quotations Enums
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}


// Price List Enums
enum PriceListCategory {
  CARD_DESIGN
  FLEX_DESIGN
  BANNER
  STICKER
  SIGNAGE_BOARD
  OTHER
}

enum PriceListSize {
  STANDARD
  EIGHT_BY_FOUR
  SIX_BY_FOUR
  THREE_BY_TWO
  CUSTOM
}

enum PriceUnit {
  PER_PIECE
  PER_SQ_FT
  PER_SET
  CUSTOM
}

// Associates Enums
enum AssociateCategory {
  INSTALLER
  FABRICATOR
  ELECTRICIAN
  HELPER
  TRANSPORT
  OTHER
}

enum AssociateStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum CostType {
  LABOUR
  MATERIAL
  TRANSPORT
  CRANE
  HELPER
  FOOD
  ACCOMMODATION
  OTHER
}

// ================= MODELS =================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Lead {
  id            String           @id @default(uuid())
  name          String
  phone         String
  email         String?
  company       String?
  source        LeadSource?
  interest      ProductInterest?
  interestOther String?
  sourceOther   String?
  status        LeadStage        @default(NEW)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
}

model Customer {
  id         String       @id @default(uuid())
  name       String
  phone      String
  email      String?
  company    String?
  gstin      String?
  imageUrl   String?
  type       CustomerType @default(RETAIL)
  address    String?
  notes      String?
  orders     Order[]
  invoices   Invoice[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Order {
  id                String        @id @default(uuid())
  orderNumber       Int           @unique @default(autoincrement())
  type              OrderType
  customer          Customer?     @relation(fields: [customerId], references: [id])
  customerId        String?
  onlineSource      OrderSource?  // Used if type is ONLINE
  onlineSourceOther String?
  buyerName         String?       // Used if type is ONLINE
  buyerContact      String?       // Used if type is ONLINE
  items             OrderItem[]
  total             Decimal       @db.Decimal(10, 2)
  amountPaid        Decimal       @default(0) @db.Decimal(10, 2)
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(UNPAID)
  note              String?
  invoices          Invoice[]
  associateProjects AssociateProject[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([customerId])
  @@index([createdAt])
}

model OrderItem {
  id           String   @id @default(uuid())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  product      String
  sku          String?
  qty          Int
  unitPrice    Decimal  @db.Decimal(10, 2)
  size         String?
  color        String?
  unit         String?
  taxRate      Decimal? @db.Decimal(10, 2)
  pricePerInch Decimal? @db.Decimal(10, 2)
  imageUrl     String?
}

model InventoryItem {
  id               String            @id @default(uuid())
  name             String
  sku              String?
  barcode          String?
  category         InventoryCategory @default(RAW_MATERIAL)
  subCategory      String?
  brand            String?
  description      String?
  
  // Material Details
  material         String?
  color            String?
  thickness        String?
  length           String?
  width            String?
  size             String?
  finish           String?
  
  // Units
  purchaseUnit     String
  usageUnit        String
  conversionFactor Decimal           @default(1) @db.Decimal(10, 2)
  
  // Costing
  lastPurchasePrice Decimal          @default(0) @db.Decimal(10, 2)
  averageCost      Decimal           @default(0) @db.Decimal(10, 2)
  
  // Inventory Tracking
  currentPurchaseStock Decimal       @default(0) @db.Decimal(10, 2)
  currentUsageStock    Decimal       @default(0) @db.Decimal(10, 2)
  minimumStock         Decimal       @default(0) @db.Decimal(10, 2)
  maximumStock         Decimal       @default(0) @db.Decimal(10, 2)
  reorderLevel         Decimal       @default(0) @db.Decimal(10, 2)
  
  // Storage Location
  warehouse        String?
  rack             String?
  shelf            String?
  bin              String?
  
  images           String[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  transactions     StockTransaction[]
  purchaseItems    PurchaseItem[]

  @@index([category])
}

model StockTransaction {
  id              String               @id @default(uuid())
  inventoryItem   InventoryItem        @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  inventoryItemId String
  type            StockTransactionType
  
  purchaseQuantity Decimal             @default(0) @db.Decimal(10, 2)
  purchaseUnit     String?
  usageQuantity    Decimal             @default(0) @db.Decimal(10, 2) // Positive or negative
  usageUnit        String?
  
  unitCost         Decimal             @default(0) @db.Decimal(10, 2)
  totalCost        Decimal             @default(0) @db.Decimal(10, 2)
  
  reason          StockTransactionReason @default(MANUAL_ADJUSTMENT)
  referenceType   ReferenceType?
  referenceId     String?
  note            String?
  createdBy       String?
  createdAt       DateTime             @default(now())

  @@index([inventoryItemId])
  @@index([type])
  @@index([createdAt])
}

model Supplier {
  id              String         @id @default(uuid())
  name            String
  companyName     String?
  contactPerson   String?
  mobile          String
  alternateMobile String?
  email           String?
  gstNumber       String?
  panNumber       String?
  address         String
  city            String
  state           String
  country         String
  pincode         String
  paymentTerms    String
  openingBalance  Decimal        @default(0) @db.Decimal(10, 2)
  status          SupplierStatus @default(ACTIVE)
  notes           String?
  purchases       Purchase[]
  expenses        Expense[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PurchaseItem {
  id              String        @id @default(uuid())
  purchase        Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId      String
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId String?
  itemName        String?
  
  purchaseQuantity Decimal      @db.Decimal(10, 2)
  purchaseUnit     String
  usageQuantity    Decimal      @db.Decimal(10, 2)
  usageUnit        String
  
  purchasePrice    Decimal      @db.Decimal(10, 2)
  unitCost         Decimal      @db.Decimal(10, 2)
  
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  tax             Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
}

model Purchase {
  id              String                 @id @default(uuid())
  purchaseNumber  String                 @unique
  referenceNumber String?
  
  purchaseType    PurchaseType           @default(CASH)
  supplier        Supplier?              @relation(fields: [supplierId], references: [id])
  supplierId      String?
  
  purchaseDate    DateTime
  paymentMethod   PaymentMethod          @default(CASH)
  paymentMethodOther String?
  paidBy          String?                @default("Company")
  paymentStatus   PurchasePaymentStatus  @default(PENDING)
  status          PurchaseDeliveryStatus @default(PENDING)
  invoiceUrl      String?
  notes           String?
  items           PurchaseItem[]
  
  subtotal        Decimal                @db.Decimal(10, 2)
  discount        Decimal                @default(0) @db.Decimal(10, 2)
  tax             Decimal                @default(0) @db.Decimal(10, 2)
  shippingCharges Decimal                @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal                @db.Decimal(10, 2)
  paidAmount      Decimal                @default(0) @db.Decimal(10, 2)
  dueAmount       Decimal                @default(0) @db.Decimal(10, 2)
  
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([purchaseDate])
  @@index([supplierId])
}

model Expense {
  id              String               @id @default(uuid())
  expenseNumber   String               @unique
  category        ExpenseCategory
  categoryOther   String?
  paidToType      PaidToType           @default(OTHER)
  paidToName      String?
  supplierId      String?
  supplier        Supplier?            @relation(fields: [supplierId], references: [id])
  amount          Decimal              @db.Decimal(10, 2)
  paidAmount      Decimal              @default(0) @db.Decimal(10, 2)
  dueAmount       Decimal              @default(0) @db.Decimal(10, 2)
  paymentMethod   PaymentMethod        @default(CASH)
  paymentMethodOther String?
  status          ExpensePaymentStatus @default(PAID)
  referenceNumber String?
  receiptUrl      String?
  spentOn         DateTime
  note            String?
  createdBy       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([spentOn])
  @@index([supplierId])
  @@index([status])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  product     String
  description String?
  quantity    Int
  unit        String
  unitPrice   Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  taxRate     Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  customer        Customer      @relation(fields: [customerId], references: [id])
  customerId      String
  order           Order?        @relation(fields: [orderId], references: [id])
  orderId         String?
  items           InvoiceItem[]
  
  subtotal        Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  tax             Decimal       @default(0) @db.Decimal(10, 2)
  shippingCharges Decimal       @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal       @default(0) @db.Decimal(10, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(10, 2)
  dueAmount       Decimal       @default(0) @db.Decimal(10, 2)

  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   PaymentMethod?
  
  template        String        @default("classic")
  status          InvoiceStatus @default(DRAFT)
  pdfUrl          String?       // Cloudinary URL if uploaded
  notes           String?
  createdBy       String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([invoiceNumber])
}


model PriceListItem {
  id         String            @id @default(uuid())
  category   PriceListCategory
  otherLabel String?           // Used if category is OTHER
  name       String
  size       PriceListSize
  sizeOther  String?           // Used if size is CUSTOM
  priceUnit  PriceUnit
  unitOther  String?           // Used if priceUnit is CUSTOM
  clientPrice Decimal          @map("price") @db.Decimal(10, 2)
  b2bPrice    Decimal?         @db.Decimal(10, 2)
  note       String?
  imageUrl   String?           // Cloudinary URL
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([category])
}

model CompanySettings {
  id            String   @id @default("1")
  companyName   String
  email         String?
  phone         String?
  address       String?
  website       String?
  gstin         String?
  logoUrl       String?
  signatureUrl  String?
  accountNo     String?
  upiId         String?
  updatedAt     DateTime @updatedAt
}

model CatalogItem {
  id           String   @id @default(uuid())
  name         String
  sku          String?
  size         String?
  color        String?
  unit         String?
  retailPrice  Decimal  @db.Decimal(10, 2)
  dealerPrice  Decimal  @db.Decimal(10, 2)
  taxPercent   Decimal? @db.Decimal(10, 2)
  imageUrl     String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ================= ASSOCIATES MODULE =================

model Associate {
  id        String            @id @default(uuid())
  name      String
  phone     String?
  address   String?
  category  AssociateCategory @default(INSTALLER)
  status    AssociateStatus   @default(ACTIVE)
  notes     String?
  projects  AssociateProject[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status])
  @@index([category])
}

model AssociateProject {
  id            String        @id @default(uuid())
  associate     Associate     @relation(fields: [associateId], references: [id])
  associateId   String
  projectName   String
  order         Order?        @relation(fields: [orderId], references: [id])
  orderId       String?
  customerName  String?
  location      String?
  description   String?
  date          DateTime      @default(now())
  status        ProjectStatus @default(PENDING)
  totalAmount   Decimal       @default(0) @db.Decimal(10, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(10, 2)
  dueAmount     Decimal       @default(0) @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(UNPAID)
  costItems     ProjectCostItem[]
  payments      ProjectPayment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([associateId])
  @@index([orderId])
  @@index([status])
}

model ProjectCostItem {
  id          String           @id @default(uuid())
  project     AssociateProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  type        CostType         @default(LABOUR)
  description String?
  quantity    Decimal          @default(1) @db.Decimal(10, 2)
  rate        Decimal          @default(0) @db.Decimal(10, 2)
  amount      Decimal          @default(0) @db.Decimal(10, 2)
}

model ProjectPayment {
  id            String           @id @default(uuid())
  project       AssociateProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  amount        Decimal          @db.Decimal(10, 2)
  paymentMethod PaymentMethod    @default(CASH)
  date          DateTime         @default(now())
  notes         String?
  createdAt     DateTime         @default(now())
}
