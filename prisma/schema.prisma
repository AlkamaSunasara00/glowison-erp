generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ================= ENUMS =================
enum Role {
  ADMIN
}

// Leads Enums
enum LeadSource {
  INDIAMART
  JUSTDIAL
  WEBSITE
  GOOGLE_ADS
  FACEBOOK_INSTAGRAM
  REFERENCE
  COLD_CALL
  OTHER
}

enum ProductInterest {
  CARD_DESIGN
  FLEX_DESIGN
  BANNER
  STICKER
  SIGNAGE_BOARD
  OTHER
}

enum LeadStage {
  NEW
  CONTACTED
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

// Customers Enums
enum CustomerType {
  RETAIL
  WHOLESALE
  ENTERPRISE
}

// Orders Enums
enum OrderType {
  RETAIL_DEALER
  ONLINE
}

enum OrderSource {
  WEBSITE
  MEESHO
  AMAZON
  INSTAGRAM
  OTHER
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// Inventory Enums
enum InventoryType {
  RAW_MATERIAL
  FINISHED_GOOD
}

enum InventoryCategory {
  FLEX
  VINYL
  ACRYLIC
  BOARD
  LED
  INK
  OTHERS
}

enum StockTransactionType {
  OPENING_STOCK
  PURCHASE
  SALE
  ADJUSTMENT
  PRODUCTION_USAGE
}

// Purchases & Expenses Enums
enum PurchasePaymentStatus {
  PAID
  PENDING
  PARTIAL
}

enum PurchaseDeliveryStatus {
  DELIVERED
  PENDING
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  UPI
  CHEQUE
  CREDIT
  CARD
  OTHER
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum ExpenseCategory {
  OFFICE_SUPPLIES
  TRAVEL
  UTILITIES
  SALARY
  MARKETING
  MAINTENANCE
  OTHER
}

enum ExpensePaymentStatus {
  PAID
  PENDING
  PARTIALLY_PAID
}

enum ExpenseStatus {
  PAID
  PENDING
}

enum PaidToType {
  SUPPLIER
  EMPLOYEE
  OTHER
}

// Invoices & Quotations Enums
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}


// Price List Enums
enum PriceListCategory {
  CARD_DESIGN
  FLEX_DESIGN
  BANNER
  STICKER
  SIGNAGE_BOARD
  OTHER
}

enum PriceListSize {
  STANDARD
  EIGHT_BY_FOUR
  SIX_BY_FOUR
  THREE_BY_TWO
  CUSTOM
}

enum PriceUnit {
  PER_PIECE
  PER_SQ_FT
  PER_SET
  CUSTOM
}

// ================= MODELS =================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Lead {
  id            String           @id @default(uuid())
  name          String
  phone         String
  email         String?
  company       String?
  source        LeadSource?
  interest      ProductInterest?
  interestOther String?
  sourceOther   String?
  status        LeadStage        @default(NEW)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
}

model Customer {
  id         String       @id @default(uuid())
  name       String
  phone      String
  email      String?
  company    String?
  gstin      String?
  imageUrl   String?
  type       CustomerType @default(RETAIL)
  address    String?
  notes      String?
  orders     Order[]
  invoices   Invoice[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Order {
  id                String        @id @default(uuid())
  orderNumber       Int           @unique @default(autoincrement())
  type              OrderType
  customer          Customer?     @relation(fields: [customerId], references: [id])
  customerId        String?
  onlineSource      OrderSource?  // Used if type is ONLINE
  onlineSourceOther String?
  buyerName         String?       // Used if type is ONLINE
  buyerContact      String?       // Used if type is ONLINE
  items             OrderItem[]
  total             Decimal       @db.Decimal(10, 2)
  amountPaid        Decimal       @default(0) @db.Decimal(10, 2)
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(UNPAID)
  note              String?
  invoices          Invoice[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([customerId])
  @@index([createdAt])
}

model OrderItem {
  id           String   @id @default(uuid())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  product      String
  sku          String?
  qty          Int
  unitPrice    Decimal  @db.Decimal(10, 2)
  size         String?
  color        String?
  unit         String?
  taxRate      Decimal? @db.Decimal(10, 2)
  pricePerInch Decimal? @db.Decimal(10, 2)
  imageUrl     String?
}

model InventoryItem {
  id               String            @id @default(uuid())
  name             String
  type             InventoryType     @default(RAW_MATERIAL)
  category         InventoryCategory
  categoryOther    String?
  size             String?
  color            String?
  sku              String?
  baseUnit         String
  purchaseUnit     String            @default("Piece")
  unitsPerPurchase Decimal           @default(1) @db.Decimal(10, 2)
  openingStock     Decimal           @default(0) @db.Decimal(10, 2)
  stockQty         Decimal           @default(0) @db.Decimal(10, 2)
  reorderThreshold Decimal           @default(10) @db.Decimal(10, 2)
  lastPurchasePrice Decimal          @default(0) @db.Decimal(10, 2)
  averageCost      Decimal           @default(0) @db.Decimal(10, 2)
  images           String[]          // Cloudinary URLs
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  transactions     StockTransaction[]
  purchaseItems    PurchaseItem[]

  @@index([category])
}

model StockTransaction {
  id              String               @id @default(uuid())
  inventoryItem   InventoryItem        @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  inventoryItemId String
  type            StockTransactionType
  quantity        Decimal              @db.Decimal(10, 2) // Positive or negative
  unitPrice       Decimal              @default(0) @db.Decimal(10, 2)
  referenceId     String?              // e.g., Purchase ID, Order ID
  note            String?
  createdAt       DateTime             @default(now())

  @@index([inventoryItemId])
  @@index([type])
  @@index([createdAt])
}

model Supplier {
  id              String         @id @default(uuid())
  name            String
  companyName     String?
  contactPerson   String
  mobile          String
  alternateMobile String?
  email           String?
  gstNumber       String?
  panNumber       String?
  address         String
  city            String
  state           String
  country         String
  pincode         String
  paymentTerms    String
  openingBalance  Decimal        @default(0) @db.Decimal(10, 2)
  status          SupplierStatus @default(ACTIVE)
  notes           String?
  purchases       Purchase[]
  expenses        Expense[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PurchaseItem {
  id              String        @id @default(uuid())
  purchase        Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId      String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId String
  purchaseUnit    String
  quantity        Decimal       @db.Decimal(10, 2)
  unitPrice       Decimal       @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  tax             Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
}

model Purchase {
  id              String                 @id @default(uuid())
  invoiceNumber   String                 @unique
  supplier        Supplier               @relation(fields: [supplierId], references: [id])
  supplierId      String
  purchaseDate    DateTime
  paymentMethod   PaymentMethod          @default(CASH)
  paymentStatus   PurchasePaymentStatus  @default(PENDING)
  deliveryStatus  PurchaseDeliveryStatus @default(PENDING)
  invoiceUrl      String?
  notes           String?
  items           PurchaseItem[]
  
  subtotal        Decimal                @db.Decimal(10, 2)
  discount        Decimal                @default(0) @db.Decimal(10, 2)
  tax             Decimal                @default(0) @db.Decimal(10, 2)
  shippingCharges Decimal                @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal                @db.Decimal(10, 2)
  paidAmount      Decimal                @default(0) @db.Decimal(10, 2)
  dueAmount       Decimal                @default(0) @db.Decimal(10, 2)
  
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([purchaseDate])
  @@index([supplierId])
}

model Expense {
  id              String               @id @default(uuid())
  expenseNumber   String               @unique
  category        ExpenseCategory
  categoryOther   String?
  paidToType      PaidToType           @default(OTHER)
  paidToName      String?
  supplierId      String?
  supplier        Supplier?            @relation(fields: [supplierId], references: [id])
  amount          Decimal              @db.Decimal(10, 2)
  paidAmount      Decimal              @default(0) @db.Decimal(10, 2)
  dueAmount       Decimal              @default(0) @db.Decimal(10, 2)
  paymentMethod   PaymentMethod        @default(CASH)
  status          ExpensePaymentStatus @default(PAID)
  referenceNumber String?
  receiptUrl      String?
  spentOn         DateTime
  note            String?
  createdBy       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([spentOn])
  @@index([supplierId])
  @@index([status])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  product     String
  description String?
  quantity    Int
  unit        String
  unitPrice   Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  taxRate     Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  customer        Customer      @relation(fields: [customerId], references: [id])
  customerId      String
  order           Order?        @relation(fields: [orderId], references: [id])
  orderId         String?
  items           InvoiceItem[]
  
  subtotal        Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  tax             Decimal       @default(0) @db.Decimal(10, 2)
  shippingCharges Decimal       @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal       @default(0) @db.Decimal(10, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(10, 2)
  dueAmount       Decimal       @default(0) @db.Decimal(10, 2)

  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   PaymentMethod?
  
  template        String        @default("classic")
  status          InvoiceStatus @default(DRAFT)
  pdfUrl          String?       // Cloudinary URL if uploaded
  notes           String?
  createdBy       String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([invoiceNumber])
}


model PriceListItem {
  id         String            @id @default(uuid())
  category   PriceListCategory
  otherLabel String?           // Used if category is OTHER
  name       String
  size       PriceListSize
  sizeOther  String?           // Used if size is CUSTOM
  priceUnit  PriceUnit
  unitOther  String?           // Used if priceUnit is CUSTOM
  clientPrice Decimal          @map("price") @db.Decimal(10, 2)
  b2bPrice    Decimal?         @db.Decimal(10, 2)
  note       String?
  imageUrl   String?           // Cloudinary URL
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([category])
}

model CompanySettings {
  id            String   @id @default("1")
  companyName   String
  email         String?
  phone         String?
  address       String?
  website       String?
  gstin         String?
  logoUrl       String?
  signatureUrl  String?
  accountNo     String?
  upiId         String?
  updatedAt     DateTime @updatedAt
}

model CatalogItem {
  id           String   @id @default(uuid())
  name         String
  sku          String?
  size         String?
  color        String?
  unit         String?
  retailPrice  Decimal  @db.Decimal(10, 2)
  dealerPrice  Decimal  @db.Decimal(10, 2)
  taxPercent   Decimal? @db.Decimal(10, 2)
  imageUrl     String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
